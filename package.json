{
  "name": "pi-session-merge",
  "version": "0.1.4",
  "description": "Pi Coding Agent Extension to import summarized context from another session.",
  "type": "module",
  "main": "./index.ts",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "test": "node --test --experimental-strip-types test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pi-package",
    "pi",
    "extension",
    "session",
    "merge"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robbirob/pi-session-merge.git"
  },
  "bugs": {
    "url": "https://github.com/robbirob/pi-session-merge/issues"
  },
  "homepage": "https://github.com/robbirob/pi-session-merge#readme",
  "license": "MIT",
  "files": [
    "index.ts",
    "src",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.9.3"
  }
